{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices", "schedule:daily"],
  "assignees": ["friedemannsommer"],
  "reviewers": ["friedemannsommer"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/[^/]+\\.ya?ml$/"
      ],
      "matchStrings": ["ZOLA_VERSION:\\s*(?<currentValue>v?\\d+\\.\\d+\\.\\d+)"],
      "depNameTemplate": "getzola/zola",
      "datasourceTemplate": "github-releases"
    }
  ]
}
